---
import type { WeightRecord } from "../lib/data";

interface Props {
  data: WeightRecord[];
}

const { data } = Astro.props;

// 最新の Body Comp データを取得
const latest = [...data].reverse().find((d) => d.muscleMass != null);
---

{latest && (
  <div class="animate-fade-up" style="animation-delay: 0.36s;">
    <h2 class="font-display text-base md:text-lg font-500 tracking-tight text-ink mb-4">メタボリクス・体組成</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 mb-6 md:mb-8">
      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm">
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">筋肉量</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.muscleMass}<span class="text-sm md:text-base font-body font-normal text-ink-muted ml-0.5">kg</span>
        </p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm">
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">骨量</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.boneMass}<span class="text-sm md:text-base font-body font-normal text-ink-muted ml-0.5">kg</span>
        </p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm">
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">水分量</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.hydration}<span class="text-sm md:text-base font-body font-normal text-ink-muted ml-0.5">kg</span>
        </p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-amber-400 to-amber-200"></div>
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">内臓脂肪</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.visceralFat}
        </p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm">
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">基礎代謝</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.basalMetabolicRate}<span class="text-sm md:text-base font-body font-normal text-ink-muted ml-0.5">kcal</span>
        </p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-5 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-accent to-indigo-300"></div>
        <p class="text-[0.65rem] font-medium tracking-[0.12em] uppercase text-ink-muted mb-3">代謝年齢</p>
        <p class="font-display text-2xl md:text-3xl font-600 tracking-tight text-ink leading-none">
          {latest.metabolicAge}<span class="text-sm md:text-base font-body font-normal text-ink-muted ml-0.5">歳</span>
        </p>
      </div>
    </div>
  </div>
)}
